<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".fragments.games.MyNumberFragment">

    <TextView
        android:id="@+id/targetNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="000"
        android:textSize="48sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/numberButtonsContainer"
        app:layout_constraintEnd_toStartOf="@id/stopTargetButton"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.35" />

    <Button
        android:id="@+id/stopTargetButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STOP"
        app:layout_constraintBaseline_toBaselineOf="@id/targetNumber"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/targetNumber"
        android:layout_marginStart="24dp" />

    <LinearLayout
        android:id="@+id/numberButtonsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/targetNumber"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/number1"
            style="@style/MyNumberBox"
            android:text="1" />

        <TextView
            android:id="@+id/number2"
            style="@style/MyNumberBox"
            android:text="2" />

        <TextView
            android:id="@+id/number3"
            style="@style/MyNumberBox"
            android:text="3" />

        <TextView
            android:id="@+id/number4"
            style="@style/MyNumberBox"
            android:text="4" />

        <TextView
            android:id="@+id/number5"
            style="@style/MyNumberBox"
            android:text="25" />

        <TextView
            android:id="@+id/number6"
            style="@style/MyNumberBox"
            android:text="50" />

    </LinearLayout>

    <Button
        android:id="@+id/stopNumbersButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STOP BROJEVI"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/numberButtonsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/expressionInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Unesi izraz"
        android:inputType="text"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/stopNumbersButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/submitButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/submit"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/expressionInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

