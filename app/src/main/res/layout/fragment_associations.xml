<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".fragments.games.AssociationsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/gameTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/asocijacije"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/associationsInfoRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/gameTitle">

            <TextView
                android:id="@+id/associationsRound"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/associations_round_label" />

            <TextView
                android:id="@+id/associationsTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/associations_time_label" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/associationsScoreRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/associationsInfoRow">

            <TextView
                android:id="@+id/associationsPlayerOneScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/player_one_score"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/associationsPlayerTwoScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="@string/player_two_score"
                android:textStyle="bold" />
        </LinearLayout>

        <GridLayout
            android:id="@+id/columnsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:columnCount="2"
            android:rowCount="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/associationsScoreRow">

            <LinearLayout
                style="@style/AssociationColumn"
                android:orientation="vertical">

                <TextView style="@style/AssociationColumnTitle" android:text="A" />
                <TextView android:id="@+id/associationA1" style="@style/AssociationField" android:text="A1" />
                <TextView android:id="@+id/associationA2" style="@style/AssociationField" android:text="A2" />
                <TextView android:id="@+id/associationA3" style="@style/AssociationField" android:text="A3" />
                <TextView android:id="@+id/associationA4" style="@style/AssociationField" android:text="A4" />
                <EditText
                    style="@style/AssociationAnswer"
                    android:hint="@string/column_solution"
                    android:inputType="text" />
            </LinearLayout>

            <LinearLayout
                style="@style/AssociationColumn"
                android:orientation="vertical">

                <TextView style="@style/AssociationColumnTitle" android:text="B" />
                <TextView android:id="@+id/associationB1" style="@style/AssociationField" android:text="B1" />
                <TextView android:id="@+id/associationB2" style="@style/AssociationField" android:text="B2" />
                <TextView android:id="@+id/associationB3" style="@style/AssociationField" android:text="B3" />
                <TextView android:id="@+id/associationB4" style="@style/AssociationField" android:text="B4" />
                <EditText
                    style="@style/AssociationAnswer"
                    android:hint="@string/column_solution"
                    android:inputType="text" />
            </LinearLayout>

            <LinearLayout
                style="@style/AssociationColumn"
                android:orientation="vertical">

                <TextView style="@style/AssociationColumnTitle" android:text="C" />
                <TextView android:id="@+id/associationC1" style="@style/AssociationField" android:text="C1" />
                <TextView android:id="@+id/associationC2" style="@style/AssociationField" android:text="C2" />
                <TextView android:id="@+id/associationC3" style="@style/AssociationField" android:text="C3" />
                <TextView android:id="@+id/associationC4" style="@style/AssociationField" android:text="C4" />
                <EditText
                    style="@style/AssociationAnswer"
                    android:hint="@string/column_solution"
                    android:inputType="text" />
            </LinearLayout>

            <LinearLayout
                style="@style/AssociationColumn"
                android:orientation="vertical">

                <TextView style="@style/AssociationColumnTitle" android:text="D" />
                <TextView android:id="@+id/associationD1" style="@style/AssociationField" android:text="D1" />
                <TextView android:id="@+id/associationD2" style="@style/AssociationField" android:text="D2" />
                <TextView android:id="@+id/associationD3" style="@style/AssociationField" android:text="D3" />
                <TextView android:id="@+id/associationD4" style="@style/AssociationField" android:text="D4" />
                <EditText
                    style="@style/AssociationAnswer"
                    android:hint="@string/column_solution"
                    android:inputType="text" />
            </LinearLayout>
        </GridLayout>

        <EditText
            android:id="@+id/finalAnswerInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/final_solution"
            android:inputType="text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/columnsContainer" />

        <Button
            android:id="@+id/submitButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/submit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/finalAnswerInput" />

        <Button
            android:id="@+id/nextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/next"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/finalAnswerInput" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
